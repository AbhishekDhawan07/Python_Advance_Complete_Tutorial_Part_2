   "source": [
    "def print1ToN(n):\n",
    "    if(n<=0): # base Case\n",
    "        return\n",
    "\n",
    "    print1ToN(n-1) # Recursion Call - Head \n",
    "\n",
    "    print(n)\n",
    "\n",
    "print1ToN(5)"
   ]
